# -------------------------------------------------------
# Euler's Market — Environment Variables
# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# -------------------------------------------------------

# Google Apps Script Web App URL
# Deploy your Apps Script as a Web App and paste the URL here.
# Guide: https://developers.google.com/apps-script/guides/web
VITE_GOOGLE_SCRIPT_URL=YOUR_GOOGLE_APPS_SCRIPT_URL_HERE

# Viva Payments Configuration
# Get these from your Viva Merchant Dashboard
VIVA_MERCHANT_ID=your_merchant_id
VIVA_API_KEY=your_api_key
VIVA_SOURCE_CODE=your_source_code

